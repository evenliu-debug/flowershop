# —— Public (browser + server) ——
# Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL for Stripe redirects and emails (no trailing slash)
# Local: http://localhost:3000  |  Vercel: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PayPal JS SDK (client) — use Sandbox Client ID for testing
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-sandbox-or-live-client-id

# —— Server only (never expose to browser) ——
# Supabase: Project Settings → API → service_role (admin scripts / optional webhooks only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe: Developers → API keys — use sk_test_… for Checkout test mode
STRIPE_SECRET_KEY=sk_test_your_secret_key

# PayPal: Sandbox developer dashboard → App credentials — REST API secret
PAYPAL_CLIENT_ID=your-paypal-rest-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret
# sandbox | live
PAYPAL_MODE=sandbox
